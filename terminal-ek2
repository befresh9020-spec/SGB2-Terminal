function handleS1(answer){
  if(caseState.s1Done)return;
  var c=cases[currentCaseIdx];
  var fb=document.getElementById('fb-s1');
  var btns=document.querySelectorAll('#step1 .choice-btn');
  var ci=answer?0:1;
  var correct=answer===c.isEinkommen;

  if(correct){
    btns[ci].classList.add('s-correct');
    btns[1-ci].classList.add('s-dim');
    fb.className='step-feedback fb-ok';
    fb.innerHTML='\u2705 Korrekt. '+c.s1Reason;
    caseState.s1Done=true;
    document.getElementById('badge-s1').className='step-badge step-badge-done';
    document.getElementById('badge-s1').textContent='\u00a7 11 \u2713';
    document.getElementById('step1').classList.add('step-done');
    var s2=document.getElementById('step2');
    s2.classList.remove('locked');
    s2.classList.add('unlock-anim');
  } else {
    btns[ci].classList.add('s-wrong');
    fb.className='step-feedback fb-err';
    fb.textContent='\u274c Nicht korrekt \u2014 pr\u00fcfe den Sachverhalt erneut.';
    setTimeout(function(){btns[ci].classList.remove('s-wrong');fb.className='step-feedback';},2000);
  }
}

/* ══════════════════════════════════════
   STEP 2 HANDLER
   ══════════════════════════════════════ */
function handleS2(answer){
  if(caseState.s2Done)return;
  var c=cases[currentCaseIdx];
  var fb=document.getElementById('fb-s2');
  var btns=document.querySelectorAll('#step2 .choice-btn');
  var map=['sgb2','mutterschaft','ferienjob','nicht_geschuetzt'];
  var ci=map.indexOf(answer);
  var correct=answer===c.s2Correct;

  if(correct){
    if(c.geschuetzt){
      btns[ci].classList.add('s-protected');
      fb.className='step-feedback fb-protected';
      fb.innerHTML='\u26a1 '+c.s2Reason.replace(/\n/g,'<br>');
      document.getElementById('badge-s2').className='step-badge step-badge-protected';
      document.getElementById('badge-s2').textContent='Gesch\u00fctzt';
      document.getElementById('step2').classList.add('step-protected');
      caseState.s2Protected=true;
      document.getElementById('check-btn').style.display='none';
      document.getElementById('next-btn').disabled=false;
      document.getElementById('check-helper').textContent='Einkommen gesch\u00fctzt \u2014 kein Anrechnungsbetrag';
    } else {
      btns[ci].classList.add('s-correct');
      fb.className='step-feedback fb-ok';
      fb.innerHTML='\u2705 Korrekt. '+c.s2Reason;
      document.getElementById('badge-s2').className='step-badge step-badge-done';
      document.getElementById('badge-s2').textContent='\u00a7 11a \u2713';
      document.getElementById('step2').classList.add('step-done');
      var s3=document.getElementById('step3');
      if(s3){s3.classList.remove('locked');s3.classList.add('unlock-anim');caseState.s3Ready=true;}
    }
    btns.forEach(function(b,i){if(i!==ci)b.classList.add('s-dim')});
    caseState.s2Done=true;
  } else {
    btns[ci].classList.add('s-wrong');
    fb.className='step-feedback fb-err';
    fb.textContent='\u274c Nicht korrekt \u2014 \u00fcberpr\u00fcfe die \u00a7 11a Voraussetzungen.';
    setTimeout(function(){btns[ci].classList.remove('s-wrong');fb.className='step-feedback';},2000);
  }
}

