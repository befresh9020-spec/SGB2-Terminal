function loadCase(idx){
  var c=cases[idx];
  resetState();
  renderProgress(idx);
  document.getElementById('case-meta').textContent='Fall '+(idx+1)+' von '+cases.length+' \u2014 '+c.title;
  document.getElementById('case-text').textContent=c.text;
  document.getElementById('case-income').innerHTML='<span>'+c.incomeLabel+'</span>';
  document.getElementById('global-result').innerHTML='';
  document.getElementById('check-btn').disabled=true;
  document.getElementById('check-btn').style.display='';
  document.getElementById('check-btn').textContent='Ergebnis pr\u00fcfen';
  document.getElementById('next-btn').disabled=true;
  document.getElementById('next-btn').style.display='';
