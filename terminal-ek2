function renderProgress(idx){
  var bar=document.getElementById('progress-bar');
  bar.innerHTML='';
  for(var i=0;i<cases.length;i++){
    var seg=document.createElement('div');
    seg.classList.add('progress-seg');
    if(i<idx)seg.classList.add('filled');
    bar.appendChild(seg);
  }
  document.getElementById('prog-count').textContent=(idx+1)+' / '+cases.length;
}

