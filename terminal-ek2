var cDisp='0',cPrev=null,cOper=null,cNew=true;
function toggleCalc(){
  var p=document.getElementById('calc-panel'),f=document.getElementById('calc-fab');
  if(p.classList.contains('open')){p.classList.remove('open');f.classList.remove('active');}
  else{p.classList.add('open');f.classList.add('active');}
}
function cUpdate(){
  document.getElementById('calc-main').textContent=cDisp;
  var sym={'add':'+','sub':'\u2212','mul':'\u00d7','div':'\u00f7'};
  document.getElementById('calc-sub').textContent=cPrev!==null?cPrev+' '+(sym[cOper]||''):'';
}
function cClear(){cDisp='0';cPrev=null;cOper=null;cNew=true;cUpdate();}
function cNum(n){
  if(cNew){cDisp=n==='.'?'0.':n;cNew=false;}
  else{
    if(n==='.'&&cDisp.indexOf('.')>=0)return;
    if(cDisp==='0'&&n!=='.')cDisp=n;
    else cDisp+=n;
  }
  cUpdate();
}
function cOp(op){
  if(op==='pm'){if(cDisp!=='0')cDisp=cDisp.charAt(0)==='-'?cDisp.slice(1):'-'+cDisp;cUpdate();return;}
  if(op==='pct'){cDisp=String(parseFloat(cDisp)/100);cUpdate();return;}
  if(cPrev!==null&&!cNew)cEqual();
  cPrev=cDisp;cOper=op;cNew=true;cUpdate();
}
function cEqual(){
  if(cPrev===null||cOper===null)return;
  var a=parseFloat(cPrev),b=parseFloat(cDisp),r=0;
  if(cOper==='add')r=a+b;
  else if(cOper==='sub')r=a-b;
  else if(cOper==='mul')r=a*b;
  else if(cOper==='div')r=b!==0?a/b:0;
  cDisp=parseFloat(r.toFixed(10)).toString();
  cPrev=null;cOper=null;cNew=true;cUpdate();
}

/* ══════════════════════════════════════
   HEX GRID / PARTICLES
   ══════════════════════════════════════ */
var canvas=document.getElementById('bg-canvas');
var ctx=canvas.getContext('2d');
var particles=[],hexGrid=[];
var themeColor={r:255,g:123,b:0};

function resizeCanvas(){canvas.width=window.innerWidth;canvas.height=window.innerHeight;generateHexGrid();}
function generateHexGrid(){
  hexGrid=[];var size=32,h=size*Math.sqrt(3);
  var cols=Math.ceil(canvas.width/(size*1.5))+2,rows=Math.ceil(canvas.height/h)+2;
  for(var r=0;r<rows;r++)for(var c=0;c<cols;c++)
    hexGrid.push({x:c*size*1.5,y:r*h+(c%2===1?h/2:0),size:size*0.9,pulse:Math.random()*Math.PI*2});
}
resizeCanvas();
window.addEventListener('resize',resizeCanvas);

for(var i=0;i<60;i++)particles.push({
  x:Math.random()*canvas.width,y:Math.random()*canvas.height,
  size:Math.random()*2+0.5,speed:Math.random()*0.6+0.15,
  opacity:Math.random()*0.4+0.1,drift:(Math.random()-0.5)*0.3
});

function drawHex(cx,cy,sz){
  ctx.beginPath();
  for(var i=0;i<6;i++){var a=(Math.PI/3)*i-Math.PI/6;var x=cx+sz*Math.cos(a),y=cy+sz*Math.sin(a);i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
  ctx.closePath();
}
function updateParticleColors(t){
  if(t==='orange')themeColor={r:255,g:123,b:0};
  if(t==='blue')themeColor={r:0,g:212,b:255};
  if(t==='green')themeColor={r:0,g:255,b:136};
}

var time=0;
(function animate(){
  ctx.clearRect(0,0,canvas.width,canvas.height);time+=0.008;
  hexGrid.forEach(function(h){
    var p=Math.sin(time+h.pulse)*0.5+0.5;
    ctx.strokeStyle='rgba('+themeColor.r+','+themeColor.g+','+themeColor.b+','+(0.015+p*0.015)+')';
    ctx.lineWidth=0.5;drawHex(h.x,h.y,h.size);ctx.stroke();
  });
  particles.forEach(function(p){
    ctx.fillStyle='rgba('+themeColor.r+','+themeColor.g+','+themeColor.b+','+p.opacity+')';
    ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
    if(p.size>1.5){
      ctx.fillStyle='rgba('+themeColor.r+','+themeColor.g+','+themeColor.b+','+(p.opacity*0.3)+')';
      ctx.beginPath();ctx.arc(p.x,p.y,p.size*3,0,Math.PI*2);ctx.fill();
    }
    p.y-=p.speed;p.x+=p.drift;
    if(p.y<-10){p.y=canvas.height+10;p.x=Math.random()*canvas.width;}
    if(p.x<-10)p.x=canvas.width+10;
    if(p.x>canvas.width+10)p.x=-10;
  });
  requestAnimationFrame(animate);
})();

