function switchTheme(t){
  var ov=document.getElementById('transition-overlay');
  ov.classList.add('active');
  setTimeout(function(){
    document.body.setAttribute('data-theme',t);
    updateParticleColors(t);
    document.querySelectorAll('.theme-btn').forEach(function(b){b.classList.remove('active')});
    var ab=document.querySelector('.theme-btn[data-theme="'+t+'"]');
    if(ab)ab.classList.add('active');
    localStorage.setItem('preferredTheme',t);
    setTimeout(function(){ov.classList.remove('active')},400);
  },300);
}
window.addEventListener('DOMContentLoaded',function(){
  var t=localStorage.getItem('preferredTheme')||'orange';
  document.body.setAttribute('data-theme',t);
