var noiseCanvas=document.getElementById('noise-canvas');
var nCtx=noiseCanvas.getContext('2d');
var NS=128;noiseCanvas.width=NS;noiseCanvas.height=NS;
var imgData=nCtx.createImageData(NS,NS),d=imgData.data;
function drawNoise(){for(var i=0;i<d.length;i+=4){var v=Math.random()*12;d[i]=v;d[i+1]=v;d[i+2]=v;d[i+3]=8;}nCtx.putImageData(imgData,0,0);}
setInterval(drawNoise,80);drawNoise();

/* ══════════════════════════════════════
   BACK BUTTON
   ══════════════════════════════════════ */
function triggerBackClick(e){
  e.preventDefault();
  var ripple=document.getElementById('back-ripple'),btn=document.getElementById('btn-back');
  var rect=btn.getBoundingClientRect();
  ripple.style.left=(e.clientX-rect.left-5)+'px';
  ripple.style.top=(e.clientY-rect.top-5)+'px';
  ripple.classList.remove('active');void ripple.offsetWidth;ripple.classList.add('active');
  setTimeout(function(){window.location.href='index.html';},400);
}
</script>

