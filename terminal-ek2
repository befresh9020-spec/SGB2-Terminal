  return '<div class="result-box '+cls+'">'+icon+' <strong>'+label+'</strong>: '+fe(uv)+extra+'<span class="r-detail">'+reason+'</span></div>';
}
function fe(v){return v.toFixed(2).replace('.',',')+' \u20ac';}

