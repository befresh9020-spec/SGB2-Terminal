function updateCheckState(){
  if(!caseState.s3Ready)return;
  var a1=document.getElementById('inp-abs1');
  var a2=document.getElementById('inp-abs2');
  var a3=document.getElementById('inp-abs3');
  var res=document.getElementById('inp-result');
  var v1=pv(a1),v2=pv(a2),v3=pv(a3);
  var sum=v1+v2+v3;
  document.getElementById('sum-absetz').textContent=sum.toFixed(2).replace('.',',')+' \u20ac';
  var allFilled=a1.value!==''&&a2.value!==''&&a3.value!==''&&res.value!=='';
  document.getElementById('check-btn').disabled=!allFilled;
  document.getElementById('check-helper').textContent=allFilled?'Bereit f\u00fcr die Auswertung':'Alle Felder ausf\u00fcllen';
}
function pv(el){if(!el||el.value==='')return 0;return parseFloat(el.value.replace(',','.'))||0;}
function handleEnterKey(e){if(e.key==='Enter'){var cb=document.getElementById('check-btn');if(!cb.disabled)cb.click();}}

/* ══════════════════════════════════════
   GLOBAL CHECK
   ══════════════════════════════════════ */
document.getElementById('check-btn').addEventListener('click',function(){
  if(caseState.checked)return;
  caseState.checked=true;
  var c=cases[currentCaseIdx];
  var btn=this;
  btn.disabled=true;
  btn.textContent='Systemanalyse l\u00e4uft...';

  ['inp-abs1','inp-abs2','inp-abs3','inp-result'].forEach(function(id){
    var el=document.getElementById(id);if(el)el.disabled=true;
  });

  setTimeout(function(){
    var u1=pv(document.getElementById('inp-abs1'));
    var u2=pv(document.getElementById('inp-abs2'));
    var u3=pv(document.getElementById('inp-abs3'));
    var uR=pv(document.getElementById('inp-result'));

    var ok1=Math.abs(u1-c.abs1)<0.01;
    var ok2=Math.abs(u2-c.abs2)<0.01;
    var ok3=Math.abs(u3-c.abs3)<0.01;
    var okR=Math.abs(uR-c.anzurechnen)<0.01;
    var allOk=ok1&&ok2&&ok3&&okR;

    var gr=document.getElementById('global-result');
    var html='';

    html+=rl('\u00a7 11b Abs. 1',u1,c.abs1,ok1,c.abs1Reason);
    html+=rl('\u00a7 11b Abs. 2',u2,c.abs2,ok2,c.abs2Reason+(c.abs2Detail?'\n\u26a1 '+c.abs2Detail:''));
    html+=rl('\u00a7 11b Abs. 3',u3,c.abs3,ok3,c.abs3Reason);
    html+='<hr class="calc-divider">';

    if(allOk){
      html+='<div class="result-box result-ok">\u2705 <strong>Korrekt!</strong> Alle Absetzbetr\u00e4ge und das anzurechnende Einkommen stimmen.<span class="r-detail">'+c.resultDetail+'</span></div>';
    } else if(okR){
      html+='<div class="result-box result-partial">\u26a0\ufe0f Richtiges Endergebnis, aber Zwischenschritte pr\u00fcfen!<span class="r-detail">'+c.resultDetail+'</span></div>';
    } else {
      html+='<div class="result-box result-wrong">\u274c Anzurechnendes Einkommen: Deine Eingabe '+fe(uR)+' \u2014 korrekt w\u00e4re '+fe(c.anzurechnen)+'<span class="r-detail">'+c.resultDetail+'</span></div>';
    }

    gr.innerHTML=html;
    document.getElementById('badge-s3').className='step-badge '+(allOk?'step-badge-done':'step-badge-pending');
    document.getElementById('badge-s3').textContent=allOk?'\u00a7 11b \u2713':'Siehe Erkl\u00e4rung';
    if(allOk)document.getElementById('step3').classList.add('step-done');

    btn.style.display='none';
    document.getElementById('next-btn').disabled=false;
    document.getElementById('check-helper').textContent='';
    gr.scrollIntoView({behavior:'smooth',block:'start'});
  },500);
});

function rl(label,uv,cv,ok,reason){
  var cls=ok?'result-ok':'result-wrong';
  var icon=ok?'\u2705':'\u274c';
