<!DOCTYPE html>

<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Roboto+Mono:wght@300;400;600&display=swap" rel="stylesheet">
  <title>SGB II Einkommensanrechnung §§ 11, 11a, 11b</title>
<style>
/* ═══════════════════════════════════════════════════════════
   EINKOMMENSANRECHNUNG TERMINAL — §§ 11, 11a, 11b SGB II
   Metroid Prime HUD / Visor aesthetic
   ═══════════════════════════════════════════════════════════ */

:root {
--bg-dark: #050a0a;
--bg-panel: rgba(8, 18, 14, 0.93);
--primary: #ff7b00;
--primary-dim: rgba(255, 123, 0, 0.08);
--primary-glow: rgba(255, 123, 0, 0.55);
--primary-mid: rgba(255, 123, 0, 0.35);
--text-main: #e8dfc0;
--text-dim: #8a7a5a;
--success: #6dffb3;
--warning: #ffe066;
--danger: #ff4444;
--border: rgba(255, 123, 0, 0.35);
--hex: rgba(255, 123, 0, 0.06);
--font-tech:"Orbitron", sans-serif;
--font-mono: "Roboto Mono", monospace;
}
[data-theme="blue"] {
--primary: #00d4ff;
--primary-dim: rgba(0, 212, 255, 0.08);
--primary-glow: rgba(0, 212, 255, 0.55);
--primary-mid: rgba(0, 212, 255, 0.3);
--text-main: #c8e8f8;
--text-dim: #5a7a8a;
--border: rgba(0, 212, 255, 0.3);
--hex: rgba(0, 212, 255, 0.05);
}
[data-theme="green"] {
--primary: #00ff88;
--primary-dim: rgba(0, 255, 136, 0.08);
--primary-glow: rgba(0, 255, 136, 0.55);
--primary-mid: rgba(0, 255, 136, 0.3);
--text-main: #c8f0d8;
--text-dim: #5a8a6a;
--border: rgba(0, 255, 136, 0.3);
--hex: rgba(0, 255, 136, 0.05);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { background-color: #050a0a; }
body {
background-color: var(--bg-dark); color: var(--text-main);
font-family: var(--font-tech); min-height: 100vh;
overflow-x: hidden; line-height: 1.5; -webkit-font-smoothing: antialiased;
transition: color 0.4s, background-color 0.4s;
}
::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: rgba(0,0,0,0.6); border-left: 1px solid var(--border); }
::-webkit-scrollbar-thumb { background: var(--primary-mid); }
::-webkit-scrollbar-thumb:hover { background: var(--primary); box-shadow: 0 0 10px var(--primary-glow); }

/* ─── HINTERGRUND ─── */
#bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2; }
.visor-overlay {
position: fixed; top: 0; left: 0; width: 100%; height: 100%;
background: radial-gradient(ellipse at 50% 40%, transparent 30%, rgba(0,0,0,0.25) 65%, rgba(0,0,0,0.75) 100%);
pointer-events: none; z-index: 997;
}
.visor-rim {
position: fixed; top: 0; left: 0; width: 100%; height: 100%;
background:
linear-gradient(to bottom, rgba(255,123,0,0.07) 0%, transparent 8%),
linear-gradient(to top, rgba(255,123,0,0.07) 0%, transparent 8%),
linear-gradient(to right, rgba(255,123,0,0.04) 0%, transparent 6%),
linear-gradient(to left, rgba(255,123,0,0.04) 0%, transparent 6%);
pointer-events: none; z-index: 998; transition: background 0.5s;
}
[data-theme="blue"] .visor-rim {
background:
linear-gradient(to bottom, rgba(0,212,255,0.07) 0%, transparent 8%),
linear-gradient(to top, rgba(0,212,255,0.07) 0%, transparent 8%),
linear-gradient(to right, rgba(0,212,255,0.04) 0%, transparent 6%),
linear-gradient(to left, rgba(0,212,255,0.04) 0%, transparent 6%);
}
[data-theme="green"] .visor-rim {
background:
linear-gradient(to bottom, rgba(0,255,136,0.07) 0%, transparent 8%),
linear-gradient(to top, rgba(0,255,136,0.07) 0%, transparent 8%),
linear-gradient(to right, rgba(0,255,136,0.04) 0%, transparent 6%),
linear-gradient(to left, rgba(0,255,136,0.04) 0%, transparent 6%);
}
.scanlines {
position: fixed; top: 0; left: 0; width: 100%; height: 200%;
background: repeating-linear-gradient(to bottom, transparent 0px, transparent 2px, rgba(0,0,0,0.18) 2px, rgba(0,0,0,0.18) 4px);
pointer-events: none; z-index: 1001; opacity: 0.65; animation: scanroll 8s linear infinite;
}
@keyframes scanroll { 0% { transform: translateY(0); } 100% { transform: translateY(-50%); } }
#noise-canvas {
position: fixed; top: 0; left: 0; width: 100%; height: 100%;
pointer-events: none; z-index: 1002; opacity: 1; mix-blend-mode: screen; image-rendering: pixelated;
}

/* ─── TOP BAR ─── */
.top-bar {
display: flex; justify-content: space-between; align-items: center;
padding: 8px 20px; background: rgba(0,0,0,0.88);
border-bottom: 1px solid var(--border); backdrop-filter: blur(8px);
position: sticky; top: 0; z-index: 1000;
transition: border-color 0.4s, box-shadow 0.4s;
box-shadow: 0 4px 20px var(--primary-glow);
}
.visor-mode {
font-size: 0.6rem; letter-spacing: 3px; color: var(--primary);
text-transform: uppercase; opacity: 0.7; font-family: var(--font-mono); transition: color 0.4s;
}
.top-bar-ticks { display: flex; gap: 5px; align-items: center; }
.top-bar-ticks span { display: block; height: 12px; width: 2px; background: var(--primary); opacity: 0.4; transition: background 0.4s; }
.top-bar-ticks span:nth-child(3) { opacity: 0.9; height: 18px; }
.theme-switch { display: flex; gap: 14px; align-items: center; }
.theme-btn {
background: transparent; border: 1px solid var(--text-dim); color: var(--text-dim);
width: 32px; height: 32px; border-radius: 50%; cursor: pointer; transition: 0.3s;
display: grid; place-items: center; font-size: 0.7rem; position: relative;
padding: 0; min-height: unset; flex: unset; clip-path: none; overflow: visible;
}
.theme-btn::before { display: none; }
.theme-btn:hover, .theme-btn:focus { border-color: var(--text-main); color: var(--text-main); outline: none; background: transparent; box-shadow: none; }
.theme-btn.active { border-color: var(--primary); color: var(--primary); box-shadow: 0 0 10px var(--primary-glow), inset 0 0 6px var(--primary-dim); }
.theme-btn.active::after { content: ""; position: absolute; inset: -5px; border-radius: 50%; border: 1px solid var(--primary); opacity: 0.3; animation: pulse-ring 2s infinite; }
@keyframes pulse-ring { 0% { transform: scale(1); opacity: 0.3; } 50% { transform: scale(1.15); opacity: 0.1; } 100% { transform: scale(1); opacity: 0.3; } }

.theme-transition-overlay { position: fixed; inset: 0; pointer-events: none; z-index: 9999; opacity: 0; transition: opacity 0.3s ease; }
.theme-transition-overlay.active { opacity: 1; }
.theme-transition-overlay::after { content: ""; position: absolute; inset: 0; background: var(--primary); opacity: 0; mix-blend-mode: screen; animation: pulseGlow 0.8s ease-out; }
@keyframes pulseGlow { 0% { opacity: 0; transform: scale(0.8); } 50% { opacity: 0.4; transform: scale(1.1); } 100% { opacity: 0; transform: scale(1.5); } }

/* ─── CONTAINER ─── */
.container { max-width: 920px; margin: 24px auto; padding: 0 18px; padding-bottom: 60px; }

/* ─── PROGRESS ─── */
.progress-container { margin-bottom: 28px; }
.progress-text { display: flex; justify-content: space-between; font-size: 0.68rem; color: var(--text-dim); text-transform: uppercase; font-family: var(--font-mono); letter-spacing: 1px; margin-bottom: 10px; }
.progress-text span:last-child { color: var(--primary); }
.progress-bar { height: 6px; background: rgba(255,255,255,0.05); width: 100%; display: flex; gap: 3px; }
.progress-seg { flex: 1; background: rgba(255,255,255,0.05); position: relative; overflow: hidden; }
.progress-seg.filled { background: var(--primary); box-shadow: 0 0 8px var(--primary); }
.progress-seg.filled::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent 60%, rgba(255,255,255,0.25)); }

/* ─── TERMINAL WINDOW ─── */
.terminal-window {
background: var(--bg-panel); border: 1px solid var(--border);
box-shadow: 0 0 40px rgba(0,0,0,0.7), inset 0 0 60px var(--primary-dim), 0 0 1px var(--primary-mid);
position: relative; backdrop-filter: blur(12px); border-radius: 2px; transition: border-color 0.4s, box-shadow 0.4s;
}
.terminal-window::before { content: ""; position: absolute; inset: 0; background-image: radial-gradient(circle, var(--hex) 1px, transparent 1px); background-size: 28px 28px; pointer-events: none; border-radius: 2px; }
.hud-frame { position: relative; }
.hud-frame::before, .hud-frame::after, .hud-frame .hud-corner-br, .hud-frame .hud-corner-bl { content: ""; position: absolute; width: 28px; height: 28px; pointer-events: none; z-index: 10; transition: border-color 0.4s, box-shadow 0.4s; }
.hud-frame::before { top: -2px; left: -2px; border-top: 3px solid var(--primary); border-left: 3px solid var(--primary); box-shadow: -2px -2px 8px var(--primary-glow); }
.hud-frame::after { top: -2px; right: -2px; border-top: 3px solid var(--primary); border-right: 3px solid var(--primary); box-shadow: 2px -2px 8px var(--primary-glow); }
.hud-corner-br { bottom: -2px; right: -2px; border-bottom: 3px solid var(--primary); border-right: 3px solid var(--primary); box-shadow: 2px 2px 8px var(--primary-glow); }
.hud-corner-bl { bottom: -2px; left: -2px; border-bottom: 3px solid var(--primary); border-left: 3px solid var(--primary); box-shadow: -2px 2px 8px var(--primary-glow); }

.terminal-header {
padding: 18px 24px 14px; border-bottom: 1px solid var(--border);
background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 100%);
display: flex; flex-direction: column; align-items: center; position: relative; gap: 4px;
}
.terminal-header::after { content: ""; position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%); width: 60%; height: 2px; background: linear-gradient(90deg, transparent, var(--primary), transparent); box-shadow: 0 0 10px var(--primary); }
.terminal-title { font-size: 1.15rem; color: var(--primary); text-transform: uppercase; letter-spacing: 5px; text-shadow: 0 0 14px var(--primary-glow), 0 0 40px var(--primary-mid); text-align: center; }
.terminal-subtitle { font-size: 0.68rem; color: var(--text-dim); font-family: var(--font-mono); text-align: center; letter-spacing: 2px; }
.case-meta { font-family: var(--font-mono); font-size: 0.6rem; color: var(--primary); letter-spacing: 1px; margin-top: 2px; opacity: 0.7; }
.terminal-content { padding: 24px; position: relative; }

/* ─── REFERENCE PANEL ─── */
.ref-panel { margin-bottom: 20px; border: 1px solid var(--border); background: rgba(0,0,0,0.20); overflow: hidden; }
.ref-toggle {
width: 100%; background: transparent; border: none; padding: 10px 16px;
display: flex; align-items: center; justify-content: space-between; cursor: pointer;
font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 2px;
text-transform: uppercase; color: var(--text-dim); clip-path: none; min-height: unset;
flex: unset; text-align: left; transition: color 0.25s, background 0.25s;
}
.ref-toggle span:first-child { white-space: normal; line-height: 1.4; padding-right: 12px; }
.ref-toggle:hover { color: var(--primary); background: var(--primary-dim); }
.ref-toggle::before { display: none; }
.ref-toggle .arr { font-size: 0.6rem; transition: transform 0.3s; flex-shrink: 0; }
.ref-panel.open .arr { transform: rotate(180deg); }
.ref-body { display: none; border-top: 1px solid var(--border); padding: 12px 16px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
.ref-panel.open .ref-body { display: block; }
.ref-table { width: 100%; min-width: 400px; border-collapse: collapse; font-family: var(--font-mono); font-size: 0.7rem; }
.ref-table th { text-align: left; color: var(--text-dim); font-weight: 400; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 10px 8px 0; border-bottom: 1px solid var(--border); }
.ref-table td { padding: 6px 10px 6px 0; border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: top; line-height: 1.5; color: var(--text-main); }
.ref-table tr:last-child td { border-bottom: none; }
.ref-table .t-stufe { color: var(--primary); font-weight: 600; white-space: nowrap; }
.ref-table .t-para { color: var(--text-dim); font-size: 0.62rem; }
.ref-table .t-amt { color: var(--success); font-weight: 600; text-align: right; white-space: nowrap; text-shadow: 0 0 6px rgba(109,255,179,0.3); }

/* ─── CASE TEXT ─── */
.case-text {
background: rgba(0,0,0,0.4); border-left: 2px solid var(--primary);
border-bottom: 1px solid rgba(255,255,255,0.05); padding: 14px 16px; margin-bottom: 6px;
font-family: var(--font-mono); font-size: 0.88rem; color: var(--text-main);
line-height: 1.65; position: relative;
}
.case-text::before { content: ""; position: absolute; top: 0; right: 0; width: 0; height: 0; border-style: solid; border-width: 0 16px 16px 0; border-color: transparent var(--primary) transparent transparent; opacity: 0.4; }
.case-income {
font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 2px;
color: var(--text-dim); text-transform: uppercase; padding: 8px 0 16px;
border-bottom: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;
}
.case-income span { color: var(--primary); }

/* ─── STEP BLOCKS ─── */
.step-block {
border: 1px solid var(--border); background: rgba(0,0,0,0.22);
margin-bottom: 14px; transition: all 0.35s;
}
.step-block.locked { opacity: 0.35; filter: grayscale(0.4); pointer-events: none; }
.step-block.step-done { border-color: rgba(109,255,179,0.30); }
.step-block.step-protected { border-color: rgba(255,224,102,0.30); }
.step-head {
display: flex; align-items: center; justify-content: space-between;
padding: 11px 16px; border-bottom: 1px solid var(--border);
background: rgba(0,0,0,0.30); gap: 10px;
}
.step-head-left { display: flex; align-items: center; gap: 8px; }
.s-num {
display: inline-flex; align-items: center; justify-content: center;
width: 22px; height: 22px; border: 1px solid var(--text-dim);
font-family: var(--font-mono); font-size: 0.55rem; flex-shrink: 0;
transition: border-color 0.3s, color 0.3s;
}
.step-done .s-num { border-color: var(--success); color: var(--success); }
.step-protected .s-num { border-color: var(--warning); color: var(--warning); }
.step-hdr-label { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); }
.step-badge { font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 1px; padding: 3px 7px; border: 1px solid; text-transform: uppercase; white-space: nowrap; transition: all 0.3s; }
.step-badge-pending { border-color: rgba(255,255,255,0.12); color: var(--text-dim); }
.step-badge-done { border-color: var(--success); color: var(--success); text-shadow: 0 0 6px rgba(109,255,179,0.4); }
.step-badge-protected { border-color: var(--warning); color: var(--warning); }
.step-body { padding: 12px 16px; }

/* ─── CHOICE BUTTONS ─── */
.choice-grid { display: grid; gap: 8px; }
.choice-grid-2 { grid-template-columns: 1fr 1fr; }
.choice-grid-4 { grid-template-columns: 1fr 1fr; }
.choice-btn {
background: rgba(0,0,0,0.45); border: 1px solid var(--primary-mid);
color: var(--text-main); font-family: var(--font-mono); font-size: 0.7rem;
padding: 10px 12px; cursor: pointer; text-align: left; line-height: 1.5;
letter-spacing: 0.5px; position: relative; overflow: hidden;
transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
min-height: unset; flex: unset; width: 100%; box-shadow: 0 0 8px var(--primary-dim);
}
.choice-btn::before { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent); transform: translateX(-100%); transition: transform 0.35s; pointer-events: none; }
.choice-btn:hover::before { transform: translateX(100%); }
.choice-btn:hover { background: var(--primary-dim); border-color: var(--primary); color: #fff; box-shadow: 0 0 20px var(--primary-glow), inset 0 0 10px var(--primary-dim); transform: translateY(-2px); }
.choice-btn:active { transform: translateY(0); }
.choice-label { display: block; font-size: 0.78rem; font-weight: 600; color: var(--primary); margin-bottom: 3px; }
.choice-sub { display: block; font-size: 0.62rem; color: var(--text-dim); }
.choice-btn.s-correct { border-color: var(--success) !important; background: rgba(109,255,179,0.07) !important; pointer-events: none; box-shadow: inset 4px 0 0 var(--success), inset 0 0 20px rgba(109,255,179,0.15), 0 0 20px rgba(109,255,179,0.2); transform: translateY(-2px) scale(1.02); }
.choice-btn.s-correct .choice-label { color: var(--success); }
.choice-btn.s-correct .choice-sub { color: rgba(109,255,179,0.6); }
.choice-btn.s-protected { border-color: var(--warning) !important; background: rgba(255,224,102,0.07) !important; pointer-events: none; box-shadow: inset 4px 0 0 var(--warning), inset 0 0 20px rgba(255,224,102,0.15), 0 0 20px rgba(255,224,102,0.2); transform: translateY(-2px) scale(1.02); }
.choice-btn.s-protected .choice-label { color: var(--warning); }
.choice-btn.s-protected .choice-sub { color: rgba(255,224,102,0.6); }
.choice-btn.s-wrong { border-color: var(--danger) !important; background: rgba(255,68,68,0.07) !important; animation: shake 0.35s ease; }
.choice-btn.s-dim { opacity: 0.25; pointer-events: none; }
@keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }
.step-feedback { display: none; margin-top: 10px; padding: 8px 12px; border-left: 2px solid; font-family: var(--font-mono); font-size: 0.72rem; line-height: 1.65; animation: fadeUp 0.3s ease; }
.step-feedback.fb-ok { display: block; border-color: var(--success); color: var(--success); }
.step-feedback.fb-protected { display: block; border-color: var(--warning); color: var(--warning); }
.step-feedback.fb-err { display: block; border-color: var(--danger); color: var(--danger); }
.fb-hint { display: block; margin-top: 6px; font-size: 0.68rem; color: var(--warning); opacity: 0.85; }

/* ─── CALCULATION INPUTS ─── */
.calc-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; animation: fadeUp 0.3s ease; }
.calc-label { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-dim); letter-spacing: 1px; min-width: 100px; line-height: 1.4; }
.calc-label-hl { color: var(--warning); }
.input-wrapper {
padding: 4px; background: rgba(0,0,0,0.45); border: 1px solid var(--primary-mid); position: relative;
clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); box-shadow: 0 0 8px var(--primary-dim);
}
.input-wrapper:hover { background: rgba(0,0,0,0.6); border-color: var(--primary); box-shadow: 0 0 15px var(--primary-glow), inset 0 0 10px var(--primary-dim); transform: translateY(-2px); }
.input-wrapper:focus-within { background: var(--primary-mid); border-color: var(--primary); box-shadow: inset 4px 0 0 var(--primary), inset 0 0 20px var(--primary-glow), 0 0 30px var(--primary-glow), 0 0 10px var(--primary); transform: translateY(-2px) scale(1.02); z-index: 10; }
.input-wrapper::after { content: "\20AC"; position: absolute; right: 22px; top: 50%; transform: translateY(-50%); color: var(--primary); font-family: var(--font-mono); font-size: 0.9rem; opacity: 0.6; pointer-events: none; transition: all 0.3s ease; }
.input-wrapper:focus-within::after { color: #fff; text-shadow: 0 0 10px var(--primary), 0 0 20px var(--primary-glow); opacity: 1; }
.input-wrapper:has(input:disabled) { pointer-events: none; opacity: 0.85; }
.calc-input {
background: rgba(0,0,0,0.7); border: 1px solid var(--primary-mid); color: var(--success);
font-family: var(--font-mono); font-size: 1.05rem; font-weight: 600;
padding: 8px 40px 8px 12px; width: 150px; outline: none; border-radius: 0;
appearance: none; text-align: right; text-shadow: 0 0 8px rgba(109,255,179,0.5); transition: all 0.3s ease;
}
.calc-input::-webkit-outer-spin-button, .calc-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.calc-input[type=number] { -moz-appearance: textfield; }
.calc-input::placeholder { color: var(--text-dim); opacity: 0.5; }
.calc-input:focus { border-color: var(--primary); color: #fff; text-shadow: 0 0 10px var(--success), 0 0 20px var(--success); box-shadow: inset 0 0 15px rgba(0,0,0,0.8); }
.calc-input:disabled { background: rgba(0,0,0,0.3); text-shadow: none; cursor: not-allowed; }
.calc-divider { border: none; border-top: 1px dashed var(--border); margin: 12px 0 10px; }
.calc-total { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-dim); display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.calc-total-value { color: var(--primary); font-weight: 600; font-size: 0.9rem; text-shadow: 0 0 8px var(--primary-glow); }

/* ─── RESULT ─── */
.result-box { padding: 12px 16px; border-left: 3px solid; font-family: var(--font-mono); font-size: 0.76rem; line-height: 1.65; animation: fadeUp 0.4s ease; margin-bottom: 8px; }
.result-ok { border-color: var(--success); color: var(--success); background: rgba(109,255,179,0.04); }
.result-partial { border-color: var(--warning); color: var(--warning); background: rgba(255,224,102,0.04); }
.result-wrong { border-color: var(--danger); color: var(--danger); background: rgba(255,68,68,0.04); }
.r-detail { display: block; margin-top: 6px; padding: 6px 10px; background: rgba(255,255,255,0.04); border-left: 2px solid currentColor; color: var(--text-main); font-size: 0.73rem; line-height: 1.55; white-space: pre-line; }
